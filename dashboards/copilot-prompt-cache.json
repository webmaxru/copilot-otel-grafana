      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"execute_tool\" && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "A" }],
