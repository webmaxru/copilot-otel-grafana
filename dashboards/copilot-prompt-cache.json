    {
      "title": "Operations Over Time",
      "description": "LLM calls, agent invocations, and tool executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        { "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"chat\" && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "chat" },
        { "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"invoke_agent\" && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "agent" },
        { "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"execute_tool\" && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "tools" }
