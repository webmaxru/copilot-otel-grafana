      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"], "placement": "bottom" } }
    },
    {
      "title": "Cache Hit vs Miss Over Time",
      "description": "Green = cache reads (savings), Orange = cache creations (new entries)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        { "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.usage.cache_read.input_tokens > 0 && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "hits" },
        { "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.usage.cache_creation.input_tokens > 0 && resource.service.name = \"copilot-chat\" } | count_over_time()", "refId": "misses" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "hits" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "misses" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"], "placement": "bottom" } }
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }, "id": 102, "title": "Model Performance", "type": "row" },
    {
      "title": "Calls by Model",
