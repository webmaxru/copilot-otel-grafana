      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"chat\" && resource.service.name = \"copilot-chat\" } | quantile_over_time(duration, 0.5) by (span.gen_ai.request.model)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ns", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean"], "placement": "bottom" } }
