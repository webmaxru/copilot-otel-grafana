      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [{ "datasource": { "type": "tempo", "uid": "tempo" }, "queryType": "traceql", "query": "{ span.gen_ai.operation.name = \"chat\" && resource.service.name = \"copilot-chat\" } | count_over_time() by (span.gen_ai.request.model)", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"], "placement": "bottom" } }
    },
    {
