# Copy to .env and fill in. Used by docker-compose.azure.yml / the OTel Collector.
# Get the value from the Azure setup script output, or:
#   az monitor app-insights component show -g <rg> -a <name> --query connectionString -o tsv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/

# Cookieless web analytics for the docs/ promo site (Real User Monitoring) — a PUBLIC client key.
# Bundled into docs/analytics.js at build time (npm run build); in CI it comes from the repo
# variable vars.APPINSIGHTS_CONNECTION_STRING. This is a DIFFERENT resource than the collector above
# (ghcpotel-web-ai vs ghcpotel-appi). Get it with:
#   az monitor app-insights component show --app ghcpotel-web-ai -g rg-ghcp-otel --query connectionString -o tsv
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
